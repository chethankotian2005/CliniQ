# Environment Variables for SmartQueue Medical App
# Copy this file to .env and fill in your actual values

# Gemini AI API Key for Medical Chatbot
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Django Settings
SECRET_KEY=your_django_secret_key_here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Security/Origin Settings
# For production set your Vercel URL(s)
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=

# Admin Credentials (for demo/development)
ADMIN_PASSWORD=your_secure_admin_password_here

# Database Configuration (if using external database)
# DATABASE_URL=postgresql://user:password@localhost:5432/smartqueue
# DATABASE_NAME=smartqueue
# DATABASE_USER=your_db_user
# DATABASE_PASSWORD=your_db_password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# Vercel / Production Origin Settings
# CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Redis Configuration (for channels and caching)
# REDIS_URL=redis://localhost:6379/0

# Email Configuration (for notifications)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password
# EMAIL_USE_TLS=True

# Twilio Configuration (for SMS notifications)
# Get these from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEMO_PHONE_NUMBER=+1234567890

# Firebase Configuration (if using Firebase)
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_CREDENTIALS_PATH=
# FIREBASE_PROJECT_ID=your_firebase_project_id

# Production Settings
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# ALLOWED_HOSTS=.vercel.app,your-app.vercel.app
# SECURE_SSL_REDIRECT=True
# SECURE_BROWSER_XSS_FILTER=True
# SECURE_CONTENT_TYPE_NOSNIFF=True